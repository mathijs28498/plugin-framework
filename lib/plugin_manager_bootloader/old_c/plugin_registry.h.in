#pragma once

#include <stddef.h>
#include <stdbool.h>

typedef struct PluginDependencyDefinition
{
    const char *interface_name;
} PluginDependencyDefinition;

typedef struct PluginDefinition
{
    const char *interface_name;
    const char *target_name;
    const char *plugin_name;
    const PluginDependencyDefinition dependencies[@PLUGIN_DEPENDENCY_DEFINITIONS_LEN@];
    const size_t dependencies_len;
    const bool has_init;
    const bool has_shutdown;
    const bool is_static_only;
    const char *module_path;

} PluginDefinition;

typedef struct InterfaceDefinition
{
    const char *interface_name;
    const char *default_plugin;
    PluginDefinition plugin_definitions[@PLUGIN_DEFINITIONS_LEN@];
    size_t plugin_definitions_len;
} InterfaceDefinition;

typedef struct PluginRegistry
{
    InterfaceDefinition interface_definitions[@INTERFACE_DEFINITIONS_LEN@];
    size_t interface_definitions_len;
} PluginRegistry;

const PluginRegistry *plugin_registry_get(void);