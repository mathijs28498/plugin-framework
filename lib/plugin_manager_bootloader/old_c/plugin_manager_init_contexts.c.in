#include "plugin_manager_init_contexts.h"

#include <stdbool.h>
#include <stdint.h>

#include <logger_interface.h>
LOGGER_INTERFACE_REGISTER(plugin_manager_init_contexts, LOG_LEVEL_DEBUG)
#include <environment_interface.h>
#include <plugin_utils.h>

#include "plugin_manager_interface_declarations.h"
#include "plugin_manager_types.h"
#include "plugin_manager_loader.h"

int32_t plugin_manager_init_contexts(struct PluginManagerSetupContext **out_setup_context, struct PluginManagerRuntimeContext **out_runtime_context)
{
    int ret;

    static PluginManagerSetupContext setup_context = {
        .requested_plugins = {@REQUESTED_PLUGINS_TEXT@},
        .requested_plugins_len = @REQUESTED_PLUGINS_LEN@,
        .sorted_plugin_providers_indices = {@SORTED_PLUGIN_PROVIDERS_INDICES_TEXT@},
        .plugin_providers = {@PLUGIN_PROVIDERS_TEXT@},
        .plugin_providers_len = @PLUGIN_PROVIDERS_LEN@,
    };

    static PluginManagerRuntimeContext runtime_context = {0};

    *out_setup_context = &setup_context;
    *out_runtime_context = &runtime_context;
    
    ret = resolve_plugin_provider_dependencies(
        NULL,
        false,
        setup_context.plugin_providers,
        setup_context.plugin_providers_len,
        NULL,
        NULL);

    if (ret < 0)
    {
        return ret;
    }

    ret = initialize_plugins(
        NULL,
        setup_context.sorted_plugin_providers_indices,
        setup_context.plugin_providers,
        setup_context.plugin_providers_len,
        runtime_context.interface_instances,
        &runtime_context.interface_instances_len);

    if (ret < 0)
    {
        return ret;
    }

    LoggerInterface *logger_interface = (LoggerInterface *)setup_context.plugin_providers[@LOGGER_PLUGIN_PROVIDER_INDEX@].get_interface();
    setup_context.logger = logger_interface;
    runtime_context.logger = logger_interface;
    setup_context.environment = (EnvironmentInterface *)setup_context.plugin_providers[@ENVIRONMENT_PLUGIN_PROVIDER_INDEX@].get_interface();

    return 0;
}