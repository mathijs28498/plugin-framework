
#include "plugin_manager_bootloader_generated.h"

#include <stdint.h>
#include <stddef.h>
#include <stdbool.h>

#include <plugin_sdk/plugin_utils.h>
#include <plugin_sdk/plugin_sdk_types/v1/plugin_sdk_types.h>
#include <plugin_sdk/plugin_manager/v1/plugin_manager_pm_interface.h>

@PLUGIN_DEPENDENCIES_TEXT@

@PLUGIN_DEFINITIONS_TEXT@

static const InterfaceDefinition interface_definitions[] = {
@INTERFACE_DEFINITIONS_TEXT@
};

static const PluginRegistry plugin_registry = {
    .interface_definitions = interface_definitions,
    .interface_definitions_len = @INTERFACE_DEFINITIONS_LEN@,
};

const PluginRegistry *get_plugin_registry(void)
{
    return &plugin_registry;
}


@GET_PLUGIN_METADATA_FORWARD_DECLARATIONS@

#if !PLUGIN_BUILD_SHARED
CREATE_INITIALIZED_ARRAY_WITH_DECL(
    static,
    const PluginMetadata * const, 
    plugin_metadatas,
{@PLUGIN_METADATAS_TEXT@}
    );

int32_t get_bootloader_plugin_metadatas(
    const PluginRegistry* unused_plugin_registry,
    const PluginMetadata *const **out_plugin_metadatas,
    const PluginMetadata ** out_plugin_manager_metadata)
{
    (void) unused_plugin_registry;

    *out_plugin_metadatas = plugin_metadatas_.arr;
    *out_plugin_manager_metadata = @PLUGIN_MANAGER_METADATA_TEXT@;

    return 0;
}

#endif // #if !PLUGIN_BUILD_SHARED

CREATE_INITIALIZED_ARRAY_WITH_DECL(
    static const,
    RequestedPlugin, 
    requested_plugins, 
{@REQUESTED_PLUGINS_TEXT@}
    );

const RequestedPlugin *get_bootloader_requested_plugins(void){
    return requested_plugins;
}

static uint8_t base_memory_pool[@MEMORY_POOL_SIZE@];

#if @MAX_PLUGIN_AMOUNT@ < 64
#define INITIAL_OCCUPIED_BITMAP ~(0ULL) << @MAX_PLUGIN_AMOUNT@
#else // #if @MAX_PLUGIN_AMOUNT@ < 64
#define INITIAL_OCCUPIED_BITMAP 0
#endif // #if @MAX_PLUGIN_AMOUNT@ < 64

PluginFrameworkMemory *get_plugin_framework_memory(void)
{
    static PluginFrameworkMemory plugin_framework_memory = {
        .context_slab_pool = {
            .pool = base_memory_pool,
            .pool_size = @MAX_PLUGIN_AMOUNT@ * PLUGIN_CONTEXT_MEMORY_SLAB_SIZE,
            .max_plugin_amount = @MAX_PLUGIN_AMOUNT@,
            .occupied_bitmap = INITIAL_OCCUPIED_BITMAP,
        },
        .memory_pool = {
            .pool = &base_memory_pool[@MAX_PLUGIN_AMOUNT@ * PLUGIN_CONTEXT_MEMORY_SLAB_SIZE],
            .pool_size = ((uint64_t) sizeof(base_memory_pool)) - (@MAX_PLUGIN_AMOUNT@ * PLUGIN_CONTEXT_MEMORY_SLAB_SIZE),
        },
    };

    return &plugin_framework_memory;
}