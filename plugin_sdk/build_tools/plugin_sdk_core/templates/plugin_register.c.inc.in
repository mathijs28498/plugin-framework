#include <stdint.h>
#include <stdlib.h>
#include <string.h>
#include <assert.h>

#include <plugin_sdk/plugin_sdk_types/v1/plugin_sdk_types.h>
#include <plugin_sdk/plugin_utils.h>

TODO("Add context memory size and actual size in the error");
_Static_assert(sizeof(@INTERFACE_NAME_PASCAL_CASE@Context) <= PLUGIN_CONTEXT_MEMORY_SLAB_SIZE, "Context size should be less than the context memory slab size");

@INJECT_DEPENDENCY_FN_DEFINITION_TEXT@

static const PluginProvider plugin_provider = {
    .vtable = &plugin_vtable,
    .inject_dependency = @INJECT_DEPENDENCY_FN_TEXT@,
    .init = @PLUGIN_INIT_FN_TEXT@,
    .shutdown = @PLUGIN_SHUTDOWN_FN_TEXT@,
    .context_size = (uint64_t) sizeof(@INTERFACE_NAME_PASCAL_CASE@Context),
};

@PLUGIN_DEPENDENCIES_TEXT@

static const PluginLifetime supported_lifetimes[@SUPPORTED_LIFETIMES_LEN@] = {
    @SUPPORTED_LIFETIMES_TEXT@
};

extern const PluginMetadata @TARGET_NAME@_plugin_metadata = {
    .interface_name = "@INTERFACE_NAME@",
    .plugin_name = "@PLUGIN_NAME@",
    .dependencies = @PLUGIN_DEPENDENCIES_VARIABLE_TEXT@,
    .dependencies_len = @PLUGIN_DEPENDENCIES_LEN@,
    .supported_lifetimes = supported_lifetimes,
    .supported_lifetimes_len = @SUPPORTED_LIFETIMES_LEN@,
    .preferred_lifetime = @PREFERRED_LIFETIME@,
    .provider = &plugin_provider,
};

#if defined(PLUGIN_BUILD_SHARED)
// TODO: Figure out cross platform, also figure out PLUGIN_USE_SHARED with dllimport
__declspec(dllexport) const PluginMetadata *@TARGET_NAME@_get_plugin_metadata(void)
{
    return &@TARGET_NAME@_plugin_metadata;
};
#endif // #if defined(PLUGIN_BUILD_SHARED)
