add_library(@TARGET_NAME@)

target_compile_options(@TARGET_NAME@ PRIVATE ${MY_STRICT_WARNINGS})

target_sources(@TARGET_NAME@
    PRIVATE
    @SOURCE_FILE_NAMES@

    PUBLIC
    FILE_SET HEADERS
)

target_link_libraries(@TARGET_NAME@
    PRIVATE
    plugin_sdk
)

include("pluginSDK")
plugin_generate_register_inc(@TARGET_NAME@
    GEN_DIR_PATH "${CMAKE_CURRENT_BINARY_DIR}/generated"
    TOML_DIR_PATH "${CMAKE_CURRENT_LIST_DIR}"
)