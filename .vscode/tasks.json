{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Generate interface and plugin",
            "type": "shell",
            "command": "python ${workspaceFolder}/tools/gen_plugin.py --interface_name ${input:interfaceName} --plugin_name ${input:pluginName}",
            "problemMatcher": [],
        }
    ],
    "inputs": [
        {
            "id": "interfaceName",
            "type": "promptString",
            "description": "Interface name (e.g. renderer_interface)"
        },
        {
            "id": "pluginName",
            "type": "promptString",
            "description": "Plugin name (e.g. renderer_vulkan)"
        }
    ]
}