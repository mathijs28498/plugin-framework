{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Generate interface and plugin",
            "type": "shell",
            "command": "\"python\" \"${workspaceFolder}/plugin_sdk/build_tools/scripts/plugin_sdk_scaffold_plugin.py\" --interface-name \"${input:interfaceName}\" --plugin-name \"${input:pluginName}\" --plugin-base-directory \"${input:pluginBaseDirectory}\"",
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "interfaceName",
            "type": "promptString",
            "description": "Interface name (e.g. renderer)"
        },
        {
            "id": "pluginName",
            "type": "promptString",
            "description": "Plugin name (e.g. vulkan)"
        },
        {
            "id": "pluginBaseDirectory",
            "type": "promptString",
            "description": "Base directory where the plugin will be placed",
            "default": "${workspaceFolder}/plugins"
        }
    ]
}